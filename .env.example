# AI Intelligence Agent — environment variables
#
# .env is listed in .gitignore — never commit real keys.

# Required in Phase 4 (LLM summarization). Get your key at:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# (Future) Alternative LLM providers — only needed if you switch from Gemini.
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

RESEND_API_KEY=your_resend_key_here

GROQ_API_KEY=your_groq_key_here